<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.26100.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <SupportedOSPlatformVersion>10.0.22621.0</SupportedOSPlatformVersion>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyVersion>0.3.0.2</AssemblyVersion>
    <FileVersion>0.3.0.2</FileVersion>
    <NeutralLanguage>pt-BR</NeutralLanguage>
    <Platforms>AnyCPU;x64</Platforms>
    <AnalysisLevel>preview</AnalysisLevel>
    <Product>Bloco de notas - Beta</Product>
    <Version>0.3.0.2</Version>
    <Description>Bloco de notas - Beta
</Description>
    <Copyright>Gustavo Silva</Copyright>
    <Company>Gustavo Silva</Company>
    <PackageId>$(AssemblyName)</PackageId>
    <PackageIcon></PackageIcon>
    <ApplicationIcon>BlocoDeNotas.Icone.ico</ApplicationIcon>
    <DelaySign>False</DelaySign>
    <SignAssembly>True</SignAssembly>
    <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DebugType>none</DebugType>
    <IsPublishable>True</IsPublishable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <DebugType>none</DebugType>
    <IsPublishable>True</IsPublishable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DebugType>none</DebugType>
    <IsPublishable>True</IsPublishable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <DebugType>none</DebugType>
    <IsPublishable>True</IsPublishable>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="BlocoDeNotas.Icone.ico" />
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="call &quot;C:\Users\gusta\source\repos\BlocoDeNotas\Scripts\sign.bat&quot;" />
  </Target>

</Project>
