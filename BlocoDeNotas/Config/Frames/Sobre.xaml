<Page x:Class="BlocoDeNotas.Config.Frames.Sobre"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlocoDeNotas.Config.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Sobre">

    <Grid>
        <Border Background="{DynamicResource LayerFillColorAltBrush}">
            <Border.CornerRadius>
                <CornerRadius TopLeft="10" TopRight="10" BottomRight="0" BottomLeft="15"/>
            </Border.CornerRadius>
        </Border>
    </Grid>
</Page>
